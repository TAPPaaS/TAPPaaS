{
  "description": "TAPPaaS NetBird Client for accessing private zone (so you can operate as if you are local to TAPPaaS)",
  "version": "0.5",
  "tier": "app",
  "vmname": "netbird-client",
  "vmid": 800,
  "vmtag": "TAPPaaS,App",
  "zone0": "home",
  "dependsOn": [
    "cluster:vm",
    "cluster:ha",
    "templates:debian",
    "backup:vm",
    "identity:identity",
    "firewall:proxy"
  ],
  "provides": [],
  "config": {
    "cluster:vm": {
      "cores": 1,
      "memory": "1024",
      "diskSize": "4G",
      "storage": "tanka1",
      "imageType": "img",
      "image": "debian-13-generic-amd64-20260112-2355.qcow2",
      "imageLocation": "https://cdimage.debian.org/cdimage/cloud/trixie/20260112-2355",
      "cloudInit": "true",
      "bridge0": "lan"
    },
    "firewall:proxy": {
      "proxyAllowedZones": [
        "internet"
      ]
    }
  }
}
