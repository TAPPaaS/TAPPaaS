{
  "description": "Home Assistant OS (HAOS) - home automation platform",
  "version": "0.1.0",
  "releaseDate": "2026-05-22",
  "maintainer": "@ErikDaniel007",
  "status": "Testing",
  "vmname": "homeassistant",
  "vmid": 210,
  "vmtag": "TAPPaaS,App,HomeAutomation",
  "zone0": "srv_home",
  "dependsOn": [
    "cluster:vm",
    "backup:vm",
    "firewall:proxy",
    "homeassistant:config",
    "identity:identity",
    "firewall:rules",
    "alfen:ui",
    "alfen:discovery",
    "alfen:modbus",
    "sonos:audio",
    "sonos:airplay",
    "reolink:rtsp"
  ],
  "provides": [],
  "config": {
    "cluster:vm": {
      "bios": "ovmf",
      "ostype": "l26",
      "cores": 2,
      "memory": "4096",
      "diskSize": "32G",
      "storage": "tanka1",
      "imageType": "img",
      "image": "haos_ova-17.3.qcow2.xz",
      "imageLocation": "https://github.com/home-assistant/operating-system/releases/download/17.3/",
      "cloudInit": false,
      "sshAccess": false,
      "bridge0": "lan"
    },
    "firewall:rules": {
      "ports": [
        {
          "port": 8123,
          "protocol": "TCP",
          "description": "Home Assistant web UI"
        }
      ]
    },
    "firewall:proxy": {
      "proxyPort": 8123,
      "proxyAllowedZones": [
        "mgmt",
        "home",
        "work",
        "srv_home",
        "srv_work",
        "srv_cust"
      ]
    }
  }
}
