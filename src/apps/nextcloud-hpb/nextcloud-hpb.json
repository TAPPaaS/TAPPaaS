{
  "description": "Nextcloud Talk High-Performance Backend - dedicated WebSocket signaling server (nextcloud-spreed-signaling).",
  "version": "0.1.0",
  "releaseDate": "2026-06-12",
  "maintainer": "@ErikDaniel007",
  "status": "Testing",
  "vmname": "nextcloud-hpb",
  "vmid": 342,
  "vmtag": "TAPPaaS,App",
  "node": "tappaas2",
  "zone0": "srvWork",
