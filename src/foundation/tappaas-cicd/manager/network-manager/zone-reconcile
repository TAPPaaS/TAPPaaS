#!/usr/bin/env bash
#
# zone-reconcile — DEPRECATED shim (ADR-007 S5).
#
# The 4-plane zone orchestrator is now the TypeScript `network-manager`
# (manager/network-manager/network-manager.ts). This shim preserves the old
# `zone-reconcile [--apply] [--only <plane>]` entry point — used by operators
# and a presence check in firewall/test.sh — by delegating to:
#
#     network-manager reconcile [--apply] [--only <plane>]
#
# The previous bash implementation hardcoded firewall/scripts/{proxmox,switch,
# ap}-manager paths that S0 relocated, so it had been broken; network-manager
# calls the on-PATH plane bins instead. Drop this shim once no caller invokes
# `zone-reconcile` directly.
#
set -euo pipefail

if ! command -v network-manager >/dev/null 2>&1; then
    echo "[Error] zone-reconcile: network-manager not on PATH (run its install.sh)" >&2
    exit 1
fi

exec network-manager reconcile "$@"
