#!/usr/bin/env bash
#
# switch-manager — TAPPaaS physical-switch network provider (ADR-008, #339)
#
# Reconciles managed switches to zones.json (the single source of truth) so a
# zone's VLAN is carried on every node-uplink trunk. It maintains two files:
#
#   switch-configuration-actual.json   what is REALLY in the network (facts):
#       controllers, switches, and per-port topology (which node/AP/switch a
#       port connects to) + the VLAN config currently present once configured.
#   switch-configuration-desired.json  what zones.json IMPLIES — REGENERATED
#       from actual's topology + the active VLAN set (never hand-edited).
#
# Inventory (three tiers, all in actual):
#   controller  a management plane (e.g. UniFi OS) that adopts switches. Adding
#               one interrogates it → uploads its switches + ports.
#   switch      managed:auto (ports uploaded by interrogate, via a controller or
#               its own API) or managed:manual (ports added by hand).
#   port        {type,target,targetPort,...}; type ∈ node|switch|ap|device|uplink.
#
# Five-verb provider contract (ADR-008 order):
#   interrogate     live/controller/manual state → actual.json (via vendor plugin)
#   update-desired  actual topology + zones.json → desired.json (regenerated)
#   delta           desired vs actual → VLANs to add/remove per port
#   apply           push via vendor plugin, or print manual steps
#   confirm         record applied VLAN config into actual.json
#   reconcile       = the five verbs in order (apply only with --apply)
#
# Vendor automation lives in scripts/plugins/<vendor>.sh; manual.sh is the
# fallback (prints a delta for manual application). A switch with managed:manual
# always uses manual.sh even if its brand has a plugin.
#
# Usage: see `switch-manager --help`.
#

set -euo pipefail

# shellcheck source=../../tappaas-cicd/scripts/common-install-routines.sh disable=SC1091
. /home/tappaas/bin/common-install-routines.sh
# shellcheck source=../../cluster/lib/vm-net.sh disable=SC1091
. /home/tappaas/TAPPaaS/src/foundation/cluster/lib/vm-net.sh

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
readonly SCRIPT_DIR
# PLUGIN_DIR is env-overridable so tests can supply stub vendor plugins.
PLUGIN_DIR="${PLUGIN_DIR:-/home/tappaas/TAPPaaS/src/foundation/network/scripts/plugins}"; readonly PLUGIN_DIR
readonly ZONES_FILE="${CONFIG_DIR}/zones.json"
readonly ACTUAL="${CONFIG_DIR}/switch-configuration-actual.json"
readonly DESIRED="${CONFIG_DIR}/switch-configuration-desired.json"

readonly PORT_TYPES="node switch ap device uplink"
# Port types that are VLAN trunks (carry the full active VLAN set).
_is_trunk_type() { case " ${1} " in *" node "*|*" switch "*|*" ap "*|*" uplink "*) return 0;; *) return 1;; esac; }

# ── Usage ────────────────────────────────────────────────────────────

usage() {
    cat <<'EOF'
Usage: switch-manager <command> [args]

Inventory (recorded in switch-configuration-actual.json):
  add-controller <name> --vendor <v> --ip <ip> [--managed auto]
  remove-controller <name>
  add-switch <name> --vendor <v> --managed auto|manual [--controller <c>]
        [--ip <ip>] [--model <m>] [--location <l>] [--description <d>]
  remove-switch <name>
  add-port <switch> <port> --type node|switch|ap|device|uplink
        [--target <t>] [--target-port <tp>] [--mode trunk|access]
        [--zone <z>] [--native <vlan>] [--tagged 210,220] [--description <d>]
  update-port <switch> <port> [ ...same flags... ]
  remove-port <switch> <port>
  list
  list-ports [<switch>]   one line per port: actual config + drift vs zones.json
  show <controller|switch>

Reconciliation (five-verb provider contract, run in this order):
  interrogate             controller/auto switches -> actual.json (via plugin)
  update-desired          actual topology + zones.json -> desired.json
  delta                   desired-vs-actual VLAN differences per port
  apply                   push delta via plugin (manual plugin prints steps)
  confirm                 record applied VLAN config in actual.json
  reconcile [--apply]     run all five in order (apply only with --apply)

managed:manual switches are configured by hand (manual.sh prints what to tag);
managed:auto switches are programmed by their vendor plugin.
EOF
}

# ── State files ──────────────────────────────────────────────────────

ensure_files() {
    local f
    for f in "${ACTUAL}" "${DESIRED}"; do
        if [[ ! -f "${f}" ]]; then
            jq -n '{"$schema":"switch-configuration-schema.json","version":"2.0","controllers":{},"switches":{},"accessPoints":{}}' > "${f}"
        fi
    done
}

# Atomic jq update of actual: jq_actual '<filter>' [args...]
jq_actual() {
    local filter="$1"; shift
    local tmp; tmp="$(mktemp)"
    if jq "$@" "${filter}" "${ACTUAL}" > "${tmp}"; then mv "${tmp}" "${ACTUAL}"
    else rm -f "${tmp}"; die "Failed to update ${ACTUAL}"; fi
}

# Active VLAN tags as a JSON array of ints (the trunk set for node uplinks).
active_vlans_json() {
    vmnet_all_active_tags "${ZONES_FILE}" | tr ';' '\n' | sed '/^$/d' | jq -R 'tonumber' | jq -s 'sort'
}

# ── Controller inventory ─────────────────────────────────────────────

cmd_add_controller() {
    local name="$1"; shift || true
    [[ -n "${name}" ]] || die "add-controller requires a <name>"
    local vendor="" ip="" managed="auto"
    while [[ $# -gt 0 ]]; do case "$1" in
        --vendor) vendor="$2"; shift 2 ;;
        --ip) ip="$2"; shift 2 ;;
        --managed) managed="$2"; shift 2 ;;
        *) die "add-controller: unknown option '$1'" ;;
    esac; done
    [[ -n "${vendor}" ]] || die "add-controller requires --vendor"
    [[ -n "${ip}" ]] || die "add-controller requires --ip"
    jq -e --arg n "${name}" '.controllers | has($n)' "${ACTUAL}" >/dev/null \
        && die "Controller '${name}' already exists"
    jq_actual '.controllers[$n] = {vendor:$v, managementIp:$ip, managed:$mg}' \
        --arg n "${name}" --arg v "${vendor}" --arg ip "${ip}" --arg mg "${managed}"
    info "${GN}✓${CL} added controller '${name}' (${vendor}, ${ip})"
    info "  run 'switch-manager interrogate' to upload its switches + ports"
}

cmd_remove_controller() {
    local name="$1"
    [[ -n "${name}" ]] || die "remove-controller requires a <name>"
    jq -e --arg n "${name}" '.controllers | has($n)' "${ACTUAL}" >/dev/null \
        || die "Controller '${name}' not found"
    jq_actual 'del(.controllers[$n])' --arg n "${name}"
    info "${GN}✓${CL} removed controller '${name}'"
}

# ── Switch inventory ─────────────────────────────────────────────────

cmd_add_switch() {
    local name="$1"; shift || true
    [[ -n "${name}" ]] || die "add-switch requires a <name>"
    local vendor="" ip="" model="" location="" description="" managed="" controller=""
    while [[ $# -gt 0 ]]; do case "$1" in
        --vendor) vendor="$2"; shift 2 ;;
        --ip) ip="$2"; shift 2 ;;
        --managed) managed="$2"; shift 2 ;;
        --controller) controller="$2"; shift 2 ;;
        --model) model="$2"; shift 2 ;;
        --location) location="$2"; shift 2 ;;
        --description) description="$2"; shift 2 ;;
        *) die "add-switch: unknown option '$1'" ;;
    esac; done
    [[ -n "${vendor}" ]] || die "add-switch requires --vendor"
    [[ -n "${managed}" ]] || die "add-switch requires --managed (auto|manual)"
    [[ "${managed}" == "auto" || "${managed}" == "manual" ]] || die "add-switch: --managed must be 'auto' or 'manual'"
    [[ -z "${controller}" ]] || jq -e --arg c "${controller}" '.controllers | has($c)' "${ACTUAL}" >/dev/null \
        || die "controller '${controller}' not found (add-controller first)"
    jq -e --arg n "${name}" '.switches | has($n)' "${ACTUAL}" >/dev/null \
        && die "Switch '${name}' already exists (remove-switch first to recreate)"
    jq_actual '.switches[$n] = {vendor:$v, managed:$mg, controller:(if $c=="" then null else $c end), managementIp:$ip, model:$m, location:$loc, description:$d, ports:{}}' \
        --arg n "${name}" --arg v "${vendor}" --arg mg "${managed}" --arg c "${controller}" \
        --arg ip "${ip}" --arg m "${model}" --arg loc "${location}" --arg d "${description}"
    info "${GN}✓${CL} added switch '${name}' (${vendor}, ${managed}${controller:+, controller=${controller}}${ip:+, ${ip}})"
    if [[ "${managed}" == "manual" ]]; then
        info "  add its uplink ports:  switch-manager add-port ${name} <port> --type node --target tappaasN --target-port ethX"
    elif [[ -z "${controller}" ]]; then
        info "  run 'switch-manager interrogate' to upload its ports"
    fi
    return 0
}

cmd_remove_switch() {
    local name="$1"
    [[ -n "${name}" ]] || die "remove-switch requires a <name>"
    jq -e --arg n "${name}" '.switches | has($n)' "${ACTUAL}" >/dev/null || die "Switch '${name}' not found"
    jq_actual 'del(.switches[$n])' --arg n "${name}"
    info "${GN}✓${CL} removed switch '${name}'"
}

# ── Port inventory (add/update/remove) ───────────────────────────────

_port_set() { # _port_set <add|update> <switch> <port> [flags...]
    local op="$1" sw="$2" port="$3"; shift 3 2>/dev/null || die "${op}-port requires <switch> <port>"
    [[ -n "${sw}" && -n "${port}" ]] || die "${op}-port requires <switch> <port>"
    jq -e --arg n "${sw}" '.switches | has($n)' "${ACTUAL}" >/dev/null || die "Switch '${sw}' not found"
    local exists; exists=$(jq -r --arg n "${sw}" --arg p "${port}" '.switches[$n].ports | has($p)' "${ACTUAL}")
    if [[ "${op}" == "add" && "${exists}" == "true" ]]; then die "Port '${port}' already on '${sw}' (use update-port)"; fi
    if [[ "${op}" == "update" && "${exists}" != "true" ]]; then die "Port '${port}' not on '${sw}' (use add-port)"; fi

    local type="" target="" target_port="" mode="" zone="" native="" tagged="" description=""
    while [[ $# -gt 0 ]]; do case "$1" in
        --type) type="$2"; shift 2 ;;
        --target) target="$2"; shift 2 ;;
        --target-port) target_port="$2"; shift 2 ;;
        --mode) mode="$2"; shift 2 ;;
        --zone) zone="$2"; shift 2 ;;
        --native) native="$2"; shift 2 ;;
        --tagged) tagged="$2"; shift 2 ;;
        --description) description="$2"; shift 2 ;;
        *) die "${op}-port: unknown option '$1'" ;;
    esac; done
    if [[ -n "${type}" ]]; then printf '%s' "${PORT_TYPES}" | tr ' ' '\n' | grep -qxF "${type}" \
        || die "${op}-port: --type must be one of: ${PORT_TYPES}"; fi
    [[ "${op}" == "add" && -z "${type}" ]] && die "add-port requires --type (${PORT_TYPES})"

    # Start from the existing port (update) or a fresh object (add). Default mode
    # follows the type: trunk for node/switch/ap/uplink, access for device.
    local cur upd
    cur=$(jq -c --arg n "${sw}" --arg p "${port}" '.switches[$n].ports[$p] // {}' "${ACTUAL}")
    upd="${cur}"
    [[ -n "${type}" ]]        && upd=$(jq -c --arg v "${type}" '.type=$v' <<<"${upd}")
    [[ -n "${target}" ]]      && upd=$(jq -c --arg v "${target}" '.target=$v' <<<"${upd}")
    [[ -n "${target_port}" ]] && upd=$(jq -c --arg v "${target_port}" '.targetPort=$v' <<<"${upd}")
    [[ -n "${zone}" ]]        && upd=$(jq -c --arg v "${zone}" '.zone=$v' <<<"${upd}")
    [[ -n "${description}" ]] && upd=$(jq -c --arg v "${description}" '.description=$v' <<<"${upd}")
    [[ -n "${native}" ]]      && upd=$(jq -c --argjson v "${native}" '.nativeVlan=$v' <<<"${upd}")
    if [[ -n "${tagged}" ]]; then
        local tj; tj=$(echo "${tagged}" | tr ',;' '\n' | sed '/^$/d' | jq -R 'tonumber' | jq -s 'sort')
        upd=$(jq -c --argjson v "${tj}" '.taggedVlans=$v' <<<"${upd}")
    fi
    # Set mode: explicit flag wins; else derive from the (possibly new) type.
    local efftype; efftype=$(jq -r '.type // ""' <<<"${upd}")
    if [[ -n "${mode}" ]]; then upd=$(jq -c --arg v "${mode}" '.mode=$v' <<<"${upd}")
    elif [[ -z "$(jq -r '.mode // ""' <<<"${upd}")" && -n "${efftype}" ]]; then
        if _is_trunk_type "${efftype}"; then upd=$(jq -c '.mode="trunk"' <<<"${upd}")
        else upd=$(jq -c '.mode="access"' <<<"${upd}"); fi
    fi
    jq_actual '.switches[$n].ports[$p] = $port' --arg n "${sw}" --arg p "${port}" --argjson port "${upd}"
    info "${GN}✓${CL} ${sw} port ${port}: $(jq -c . <<<"${upd}")"
}

cmd_add_port()    { _port_set add "$@"; }
cmd_update_port() { _port_set update "$@"; }

cmd_remove_port() {
    local sw="$1" port="$2"
    [[ -n "${sw}" && -n "${port}" ]] || die "remove-port requires <switch> <port>"
    jq -e --arg n "${sw}" --arg p "${port}" '.switches[$n].ports | has($p)' "${ACTUAL}" >/dev/null \
        || die "Port '${port}' not found on '${sw}'"
    jq_actual 'del(.switches[$n].ports[$p])' --arg n "${sw}" --arg p "${port}"
    info "${GN}✓${CL} removed port '${port}' from '${sw}'"
}

# ── list / show ──────────────────────────────────────────────────────

cmd_list() {
    local cc sc
    cc=$(jq -r '.controllers // {} | length' "${ACTUAL}")
    sc=$(jq -r '.switches // {} | length' "${ACTUAL}")
    info "${BOLD}Controllers (${cc}):${CL}"
    jq -r '.controllers // {} | to_entries[] | "  \(.key)  [\(.value.vendor)]  \(.value.managementIp)"' "${ACTUAL}"
    info "${BOLD}Switches (${sc}):${CL}"
    jq -r '.switches // {} | to_entries[] | "  \(.key)  [\(.value.vendor)]  \(.value.managed)\(if .value.controller then " via "+.value.controller else "" end)  ports=\(.value.ports|length)"' "${ACTUAL}"
    local apc; apc=$(jq -r '.accessPoints // {} | length' "${ACTUAL}")
    [[ "${apc}" -gt 0 ]] && info "${BOLD}Access points (${apc}):${CL} (manage with ap-manager)"
    return 0
}

cmd_show() {
    local name="$1"
    [[ -n "${name}" ]] || die "show requires a <name>"
    if jq -e --arg n "${name}" '.switches | has($n)' "${ACTUAL}" >/dev/null; then
        jq --arg n "${name}" '.switches[$n]' "${ACTUAL}"
    elif jq -e --arg n "${name}" '.controllers | has($n)' "${ACTUAL}" >/dev/null; then
        jq --arg n "${name}" '.controllers[$n]' "${ACTUAL}"
    else
        die "No controller or switch named '${name}'"
    fi
}

# ── list-ports: one line per port, actual config + drift vs desired ──
# Read-only: computes the desired VLANs on the fly (same rules as update-desired)
# from actual's topology + zones, so it never writes files and is always current.
cmd_list_ports() {
    local target="${1:-}" active sw
    [[ -z "${target}" ]] || jq -e --arg n "${target}" '.switches | has($n)' "${ACTUAL}" >/dev/null \
        || die "Switch '${target}' not found"
    active=$(active_vlans_json)
    while IFS= read -r sw; do
        [[ -z "${sw}" ]] && continue
        info "${BOLD}${sw}${CL} — actual port config (drift vs zones.json):"
        jq -r --argjson active "${active}" --slurpfile z "${ZONES_FILE}" --arg sw "${sw}" '
            ($z[0]) as $zones
            | (.switches[$sw].ports // {}) | to_entries | sort_by(.key|tonumber) | .[]
            | .key as $k | .value as $p
            | ($p.type // "") as $t
            | ($p.taggedVlans // []) as $atag
            | ($p.nativeVlan // 0) as $anat
            | ($p.mode // "?") as $amode
            | (if ($t=="node" or $t=="switch" or $t=="uplink" or $t=="ap") then {mode:"trunk", tagged:$active, nat:0}
               elif $t=="device" then {mode:"access", tagged:[],
                     nat:(($p.zone // "") as $zn | if ($zn!="" and ($zones[$zn].vlantag!=null)) then $zones[$zn].vlantag else $anat end)}
               else null end) as $d
            | (if $d==null then "untouched (unmanaged)"
               elif $d.mode=="trunk" then (($d.tagged - $atag) as $add | ($atag - $d.tagged) as $rem
                    | if (($add|length)>0 or ($rem|length)>0) then "DRIFT +\($add|join(",")) -\($rem|join(","))" else "in sync" end)
               else (if ($d.nat != $anat) then "DRIFT native \($anat) -> \($d.nat)" else "in sync" end) end) as $status
            | "  port \($k): "
              + (if $t=="" then "—" else "\($t) → \($p.target // "?")\(if $p.targetPort then "/"+$p.targetPort else "" end)" end)
              + "  | actual: \($amode) "
              + (if $amode=="access" then "vlan \($anat)" else (if ($atag|length)>0 then ($atag|map(tostring)|join(",")) else "-" end) end)
              + "  | \($status)"
        ' "${ACTUAL}"
    done < <(if [[ -n "${target}" ]]; then echo "${target}"; else jq -r '.switches // {} | keys[]' "${ACTUAL}"; fi)
    [[ -n "${target}" || "$(jq -r '.switches // {} | length' "${ACTUAL}")" -gt 0 ]] || info "  (no switches in inventory)"
    return 0
}

# ── Plugin selection ─────────────────────────────────────────────────

select_plugin() {
    local vendor="$1" p
    for p in "${PLUGIN_DIR}"/*.sh; do
        [[ "$(basename "$p")" == "manual.sh" ]] && continue
        # shellcheck disable=SC1090
        ( . "$p"; plugin_supports "${vendor}" ) >/dev/null 2>&1 && { echo "$p"; return 0; }
    done
    echo "${PLUGIN_DIR}/manual.sh"
}

# Plugin for an inventory switch, honouring managed:manual (always manual.sh).
plugin_for_switch() {
    local name="$1" vendor managed
    managed=$(jq -r --arg n "${name}" '.switches[$n].managed // "auto"' "${ACTUAL}")
    [[ "${managed}" == "manual" ]] && { echo "${PLUGIN_DIR}/manual.sh"; return 0; }
    vendor=$(jq -r --arg n "${name}" '.switches[$n].vendor' "${ACTUAL}")
    select_plugin "${vendor}"
}

# ── Verb 1: interrogate (controllers + auto switches -> actual) ──────
# Merges live/controller-reported port VLAN config into actual WITHOUT clobbering
# operator topology annotations (type/target/targetPort/zone) already recorded.
cmd_interrogate() {
    info "${BOLD}interrogate${CL} (controllers + auto switches → actual.json)"
    ensure_files
    local name vendor ip plugin state tmp

    # Controllers: upload their switches + ports.
    while IFS= read -r name; do
        [[ -z "${name}" ]] && continue
        vendor=$(jq -r --arg n "${name}" '.controllers[$n].vendor' "${ACTUAL}")
        ip=$(jq -r --arg n "${name}" '.controllers[$n].managementIp' "${ACTUAL}")
        plugin=$(select_plugin "${vendor}")
        # shellcheck disable=SC1090
        ( . "${plugin}"; declare -F plugin_controller_interrogate >/dev/null ) || { info "  controller ${name}: ${vendor} plugin has no controller interrogate — skipped"; continue; }
        # shellcheck disable=SC1090
        state=$( . "${plugin}"; plugin_controller_interrogate "${name}" "${ip}" 2>/dev/null )
        if [[ -z "${state}" ]] || ! echo "${state}" | jq -e . >/dev/null 2>&1; then
            warn "  controller ${name}: no/invalid response (unreachable or rate-limited?) — left actual unchanged"; continue
        fi
        [[ "${state}" != "{}" ]] || { info "  controller ${name}: nothing uploaded"; continue; }
        tmp="$(mktemp)"
        # ACTUAL: merge each reported switch (meta + controller ref + ports, live
        # config overlaid on operator annotations); and mark each AP's wired uplink
        # switch port as an AP trunk so update-desired carries the WiFi VLANs.
        jq --arg c "${name}" --argjson st "${state}" '
            reduce ($st.switches // {} | to_entries[]) as $s (.;
              .switches[$s.key] = ((.switches[$s.key] // {}) * $s.value
                | .controller = $c | .managed = "auto"))
            | reduce ($st.aps // {} | to_entries[]) as $a (.;
                ($a.value.uplinkSwitch) as $usw | ($a.value.uplinkPort) as $up
                | if ($usw != "" and $up != "" and (.switches[$usw] != null))
                  then .switches[$usw].ports[$up] = ((.switches[$usw].ports[$up] // {}) + {type:"ap", target:$a.key, mode:"trunk"})
                  else . end )' \
            "${ACTUAL}" > "${tmp}" && mv "${tmp}" "${ACTUAL}"
        # DESIRED: auto-register discovered APs into ap-manager's inventory
        # (it keeps .accessPoints in desired), preserving any operator-set SSIDs.
        if [[ "$(echo "${state}" | jq -r '.aps // {} | length')" -gt 0 ]]; then
            tmp="$(mktemp)"
            jq --argjson st "${state}" '
                reduce ($st.aps // {} | to_entries[]) as $a (.;
                  .accessPoints[$a.key] = ((.accessPoints[$a.key] // {})
                    + {vendor:$a.value.vendor, model:$a.value.model, managementIp:$a.value.managementIp,
                       uplinkSwitch:$a.value.uplinkSwitch, uplinkPort:$a.value.uplinkPort,
                       ssids: ((.accessPoints[$a.key].ssids) // {})}))' \
                "${DESIRED}" > "${tmp}" && mv "${tmp}" "${DESIRED}"
        fi
        info "  controller ${name}: uploaded $(echo "${state}" | jq -r '.switches // {} | length') switch(es), $(echo "${state}" | jq -r '.aps // {} | length') AP(s)"
    done < <(jq -r '.controllers // {} | keys[]' "${ACTUAL}")

    # Standalone auto switches (no controller, brand has a device plugin).
    while IFS= read -r name; do
        [[ -z "${name}" ]] && continue
        plugin=$(plugin_for_switch "${name}")
        [[ "$(basename "${plugin}")" == "manual.sh" ]] && continue
        ip=$(jq -r --arg n "${name}" '.switches[$n].managementIp // ""' "${ACTUAL}")
        # shellcheck disable=SC1090
        ( . "${plugin}"; declare -F plugin_interrogate >/dev/null ) || continue
        # shellcheck disable=SC1090
        state=$( . "${plugin}"; plugin_interrogate "${name}" "${ip}" 2>/dev/null )
        echo "${state}" | jq -e . >/dev/null 2>&1 || { warn "  switch ${name}: no/invalid response — left actual unchanged"; continue; }
        [[ "${state}" != "{}" ]] || continue
        tmp="$(mktemp)"
        jq --arg n "${name}" --argjson s "${state}" '
            .switches[$n] = ((.switches[$n] // {}) * $s)' \
            "${ACTUAL}" > "${tmp}" && mv "${tmp}" "${ACTUAL}"
        info "  switch ${name}: uploaded $(echo "${state}" | jq -r '.ports // {} | length') port(s)"
    done < <(jq -r '.switches // {} | to_entries[] | select(.value.controller == null) | .key' "${ACTUAL}")
    return 0
}

# ── Verb 2: update-desired (regenerate desired from actual + zones) ──
cmd_update_desired() {
    info "${BOLD}update-desired${CL} (actual topology + zones.json → desired.json)"
    ensure_files
    local active; active=$(active_vlans_json)
    local tmp; tmp="$(mktemp)"
    # Base the new desired on the EXISTING desired (preserving .accessPoints, which
    # ap-manager owns, and any other keys), overriding only .controllers/.switches
    # — those we regenerate from actual's topology (.) + the active VLAN set. All
    # trunk ports (node/switch/uplink/ap) carry the full active set; UniFi auto-
    # manages AP-uplink ports as "all VLANs" anyway, so AP ports match that.
    jq --argjson active "${active}" --slurpfile z "${ZONES_FILE}" --slurpfile cur "${DESIRED}" '
        ($z[0]) as $zones
        | ($cur[0] // {}) as $des
        | $des
          + { controllers: (.controllers // {}),
              switches: ((.switches // {}) | map_values(
                . as $sw
                | $sw + { ports: (($sw.ports // {}) | map_values(
                    . as $p
                    | (.type // "") as $t
                    | if ($t=="node" or $t=="switch" or $t=="uplink" or $t=="ap") then
                        $p + {mode:"trunk", taggedVlans:$active}
                      elif ($t=="device") then
                        ((.zone // "") as $zn
                         | $p + {mode:"access",
                                 nativeVlan: (if ($zn!="" and ($zones[$zn].vlantag != null)) then $zones[$zn].vlantag else (.nativeVlan // 0) end)})
                      else $p end
                )) }
              )) }' "${ACTUAL}" > "${tmp}" && mv "${tmp}" "${DESIRED}"
    info "  active VLAN set: $(echo "${active}" | jq -rc 'join(",")')"
    info "  desired regenerated for $(jq -r '.switches // {} | length' "${DESIRED}") switch(es)"
    return 0
}

# ── Verb 3: delta (desired vs actual, per port) ─────────────────────
compute_delta() {
    jq -n --slurpfile d "${DESIRED}" --slurpfile a "${ACTUAL}" '
      ($d[0].switches // {}) as $des
      | ($a[0].switches // {}) as $act
      | reduce ($des | keys[]) as $sw ({};
          . + {($sw): {
              changes: [
                ($des[$sw].ports // {} | to_entries[]) as $p
                | ($act[$sw].ports[$p.key]) as $ap
                | if $p.value.mode=="trunk" then
                    ((($p.value.taggedVlans // []) - (($ap.taggedVlans) // [])) as $addv
                     | (((($ap.taggedVlans) // []) - ($p.value.taggedVlans // []))) as $delv
                     | if ($addv|length)>0 or ($delv|length)>0 then
                         {action:"trunk-vlans", port:$p.key,
                          description:"port \($p.key) (\($p.value.type // "trunk") \($p.value.target // "")) trunk: +\($addv|join(",")) -\($delv|join(","))"}
                       else empty end)
                  elif $p.value.mode=="access" then
                    (if (($p.value.nativeVlan // 0) != (($ap.nativeVlan) // 0)) then
                       {action:"access-vlan", port:$p.key,
                        description:"port \($p.key) access VLAN \(($ap.nativeVlan)//0) -> \($p.value.nativeVlan // 0)"}
                     else empty end)
                  else empty end
              ]
          }})
    '
}

cmd_delta() {
    local delta total=0 sw n
    delta=$(compute_delta)
    info "${BOLD}delta${CL} (desired vs actual)"
    while IFS= read -r sw; do
        [[ -z "${sw}" ]] && continue
        n=$(echo "${delta}" | jq -r --arg s "${sw}" '.[$s].changes | length')
        total=$((total + n))
        if [[ "${n}" -gt 0 ]]; then
            warn "  ${sw}: ${n} change(s)"
            echo "${delta}" | jq -r --arg s "${sw}" '.[$s].changes[] | "      \(.action): \(.description)"'
        else
            info "  ${GN}✓${CL} ${sw}: in sync"
        fi
    done < <(echo "${delta}" | jq -r 'keys[]')
    [[ "$(echo "${delta}" | jq -r 'keys|length')" -eq 0 ]] && info "  (no switches in inventory)"
    DELTA_TOTAL="${total}"
    return 0
}

# ── Verb 4: apply (plugin push / manual print) ──────────────────────
cmd_apply() {
    local delta sw changes plugin rc manual=0 applied=0
    delta=$(compute_delta)
    info "${BOLD}apply${CL}"
    while IFS= read -r sw; do
        [[ -z "${sw}" ]] && continue
        changes=$(echo "${delta}" | jq -c --arg s "${sw}" '{changes: .[$s].changes}')
        [[ "$(echo "${changes}" | jq '.changes|length')" -eq 0 ]] && continue
        plugin=$(plugin_for_switch "${sw}")
        rc=0
        # shellcheck disable=SC1090
        ( . "${plugin}"; plugin_apply "${sw}" "${changes}" ) || rc=$?
        if [[ "${rc}" -eq 0 ]]; then info "  ${GN}✓${CL} ${sw}: applied via $(basename "${plugin}" .sh)"; applied=$((applied+1))
        else manual=$((manual+1)); fi
    done < <(echo "${delta}" | jq -r 'keys[]')
    APPLY_MANUAL="${manual}"; APPLY_DONE="${applied}"
    return 0
}

# ── Verb 5: confirm (record applied VLAN config into actual) ────────
cmd_confirm() {
    info "${BOLD}confirm${CL} (record applied VLAN config in actual.json)"
    ensure_files
    local tmp; tmp="$(mktemp)"
    # Overlay each desired port's computed VLAN config (mode/nativeVlan/taggedVlans)
    # onto the matching actual port, preserving the actual topology annotations.
    jq --slurpfile d "${DESIRED}" '
        ($d[0].switches // {}) as $des
        | .switches |= (to_entries | map(
            .key as $sw | .value as $s
            | {key:$sw, value: ($s + {ports: (($s.ports // {}) | to_entries | map(
                .key as $pk | .value as $p
                | {key:$pk, value: ($p + (($des[$sw].ports[$pk] // {})
                    | {mode, nativeVlan, taggedVlans} | with_entries(select(.value != null))))}
              ) | from_entries)})}
          ) | from_entries)' "${ACTUAL}" > "${tmp}" && mv "${tmp}" "${ACTUAL}"
    info "  ${GN}✓${CL} actual.json updated to match applied desired state"
    return 0
}

# ── reconcile (interrogate → update-desired → delta → apply → confirm) ─
cmd_reconcile() {
    local apply="$1"
    DELTA_TOTAL=0; APPLY_MANUAL=0; APPLY_DONE=0
    cmd_interrogate; echo ""
    cmd_update_desired; echo ""
    cmd_delta; echo ""
    if [[ "${apply}" -eq 1 ]]; then
        SM_AUTOCONFIRM=1 cmd_apply; echo ""   # confirm runs right after → tell manual.sh not to ask for it
        # Record the intended config into actual.json for EVERY switch, including
        # manual ones: auto switches were just programmed by their plugin; for
        # manual switches the VLANs to tag were printed above and we record the
        # intent (you apply them on the hardware). So `reconcile --apply` always
        # updates actual — no separate `confirm` needed (it remains available).
        cmd_confirm; echo ""
        if [[ "${APPLY_MANUAL:-0}" -gt 0 ]]; then
            warn "switch-manager: ${APPLY_MANUAL} manual switch(es) — apply the VLANs printed above on the hardware (actual.json now records the intended config)."
        fi
        info "${GN}switch-manager: applied${CL} (${APPLY_DONE:-0} via plugin, ${APPLY_MANUAL:-0} manual)"
        return 0
    fi
    if [[ "${DELTA_TOTAL:-0}" -gt 0 ]]; then
        warn "switch-manager: ${DELTA_TOTAL} change(s) pending. Re-run with --apply."
        return 2
    fi
    info "${GN}switch-manager: in sync${CL}"
    return 0
}

# ── Main ─────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-}"
    [[ -z "${cmd}" || "${cmd}" == "-h" || "${cmd}" == "--help" ]] && { usage; exit 0; }
    shift || true
    [[ -f "${ZONES_FILE}" ]] || die "zones.json not found: ${ZONES_FILE}"
    ensure_files

    case "${cmd}" in
        add-controller)    cmd_add_controller "$@" ;;
        remove-controller) cmd_remove_controller "${1:-}" ;;
        add-switch)        cmd_add_switch "$@" ;;
        remove-switch)     cmd_remove_switch "${1:-}" ;;
        add-port)          cmd_add_port "$@" ;;
        update-port)       cmd_update_port "$@" ;;
        remove-port)       cmd_remove_port "${1:-}" "${2:-}" ;;
        list)              cmd_list ;;
        list-ports|--list-ports) cmd_list_ports "${1:-}" ;;
        show)              cmd_show "${1:-}" ;;
        interrogate)       cmd_interrogate ;;
        update-desired)    cmd_update_desired ;;
        delta)             cmd_delta ;;
        apply)             cmd_apply ;;
        confirm)           cmd_confirm ;;
        reconcile)
            local apply=0
            [[ "${1:-}" == "--apply" ]] && apply=1
            cmd_reconcile "${apply}"
            ;;
        *) die "Unknown command: ${cmd} (try --help)" ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
