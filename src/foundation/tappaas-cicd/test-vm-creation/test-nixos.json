{
  "description": "Test: NixOS clone on mgmt zone with HA failover to tappaas3",
  "version": "0.5",
  "vmname": "test-nixos",
  "vmid": 911,
  "vmtag": "TAPPaaS,Test",
  "node": "tappaas1",
  "zone0": "mgmt",
  "dependsOn": [
    "cluster:vm",
    "cluster:ha",
    "templates:nixos"
  ],
  "config": {
    "cluster:ha": {
      "HANode": "tappaas3",
      "replicationSchedule": "*/15"
    },
    "cluster:vm": {
      "bridge0": "lan",
      "cores": 2,
      "diskSize": "24G",
      "image": "8080",
      "imageType": "clone",
      "memory": "2048",
      "storage": "tanka1"
    }
  }
}
