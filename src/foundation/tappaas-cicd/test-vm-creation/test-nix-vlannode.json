{
  "description": "Test: NixOS clone on srv VLAN on a different node (tappaas2)",
  "version": "0.5",
  "vmname": "test-nixos-vlan-node",
  "vmid": 912,
  "vmtag": "TAPPaaS,Test",
  "node": "tappaas3",
  "zone0": "srvHome",
  "dependsOn": [
    "cluster:vm",
    "templates:nixos"
  ],
  "config": {
    "cluster:vm": {
      "bridge0": "lan",
      "cores": 2,
      "diskSize": "16G",
      "image": "8080",
      "imageType": "clone",
      "memory": "2048",
      "storage": "tanka1"
    }
  }
}
