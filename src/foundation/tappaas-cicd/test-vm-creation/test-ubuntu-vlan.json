{
  "version": "0.5.1",
  "node": "tappaas3",
  "vmid": 905,
  "vmtag": "TAPPaaS,Test",
  "vmname": "test-ubuntu-vlan",
  "zone0": "srv_home",
  "dependsOn": [
    "cluster:vm",
    "templates:debian"
  ],
  "description": "Test: Ubuntu image on srv VLAN (node tappaas3) - Ubuntu 24.04 LTS",
  "config": {
    "cluster:vm": {
      "bridge0": "lan",
      "cloudInit": "true",
      "cores": 1,
      "diskSize": "4G",
      "image": "ubuntu-24.04-server-cloudimg-amd64.img",
      "imageLocation": "https://cloud-images.ubuntu.com/releases/24.04/release",
      "imageType": "img",
      "memory": "4096",
      "storage": "tanka1"
    }
  }
}
