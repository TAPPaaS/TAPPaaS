{
  "description": "Test: Debian on tappaas3 with no HANode (no cluster:ha in dependsOn)",
  "version": "0.5",
  "vmname": "test-debian-node3-noha",
  "vmid": 904,
  "vmtag": "TAPPaaS,Test",
  "zone0": "mgmt",
  "node": "tappaas3",
  "dependsOn": [
    "cluster:vm",
    "templates:debian"
  ],
  "config": {
    "cluster:vm": {
      "bridge0": "lan",
      "cloudInit": "true",
      "cores": 1,
      "diskSize": "4G",
      "image": "debian-13-generic-amd64-20260112-2355.qcow2",
      "imageLocation": "https://cdimage.debian.org/cdimage/cloud/trixie/20260112-2355",
      "imageType": "img",
      "memory": "1024",
      "storage": "tanka1"
    }
  }
}
