{
  "version": "0.5.0",
  "node": "tappaas3",
  "vmid": 902,
  "vmtag": "TAPPaaS,Test",
  "vmname": "test-deb-vlannode",
  "zone0": "srvHome",
  "dependsOn": [
    "cluster:vm",
    "templates:debian"
  ],
  "description": "Test: Debian image on srv VLAN on a different node (tappaas3)",
  "config": {
    "cluster:vm": {
      "bridge0": "lan",
      "cloudInit": "true",
