#!/usr/bin/env bash
#
# switch-manager — TAPPaaS physical-switch network provider (ADR-008, #339)
#
# Reconciles managed switches to zones.json (the single source of truth) so a
# zone's VLAN is carried on every node-uplink trunk without manual switch
# logins. It is the `switch-manager` provider in the ADR-008 orchestrator model
# and implements the five-verb provider contract:
#
#   update-desired  zones.json → switch-configuration-desired.json (source:zones)
#   interrogate     live switch state → switch-configuration-actual.json (via plugin)
#   delta           desired vs actual → list of changes
#   apply           push changes via vendor plugin, or print manual steps
#   confirm         record applied state in actual.json; register discovered ports
#   reconcile       = the five verbs in order (apply only with --apply)
#
# Inventory is operator-managed via add/remove/list/show + port. Vendor
# automation lives in scripts/plugins/<vendor>.sh; manual.sh is the fallback
# (prints a delta for manual application). Real UniFi/MikroTik plugins are a
# later sprint — today every switch falls back to manual mode.
#
# Usage: see `switch-manager --help`.
#

set -euo pipefail

# shellcheck source=../../tappaas-cicd/scripts/common-install-routines.sh disable=SC1091
. /home/tappaas/bin/common-install-routines.sh
# shellcheck source=../../cluster/lib/vm-net.sh disable=SC1091
. /home/tappaas/TAPPaaS/src/foundation/cluster/lib/vm-net.sh

# Resolve through the /home/tappaas/bin symlink so PLUGIN_DIR finds scripts/plugins/.
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
readonly SCRIPT_DIR
readonly PLUGIN_DIR="${SCRIPT_DIR}/plugins"
readonly ZONES_FILE="${CONFIG_DIR}/zones.json"
readonly DESIRED="${CONFIG_DIR}/switch-configuration-desired.json"
readonly ACTUAL="${CONFIG_DIR}/switch-configuration-actual.json"

# ── Usage ────────────────────────────────────────────────────────────

usage() {
    cat <<'EOF'
Usage: switch-manager <command> [args]

Inventory:
  add <name> --vendor <v> --ip <ip> [--model <m>] [--location <l>] [--description <d>]
  remove <name>
  list
  show <name>

Port configuration:
  port <switch> <port> [--mode trunk|access] [--tagged 210,220,...] [--native <vlan>]
        [--zone <zone>] [--connected-to <type:target[:port]:iface>] [--mac <mac>]
        [--source zones|manual|discovered] [--description <text>]

Reconciliation (five-verb provider contract):
  update-desired          zones.json -> desired.json (source:zones ports)
  interrogate             live switches -> actual.json (via vendor plugin)
  delta                   show desired-vs-actual differences
  apply                   push delta via plugin (manual plugin prints steps)
  confirm                 record applied state in actual.json; register discovered
  reconcile [--apply]     run all five in order (apply only with --apply)

Vendors: unifi, mikrotik, generic. Without a vendor plugin, switches use the
manual fallback (delta is printed for manual application).
EOF
}

# ── State files ──────────────────────────────────────────────────────

ensure_files() {
    local f
    for f in "${DESIRED}" "${ACTUAL}"; do
        if [[ ! -f "${f}" ]]; then
            jq -n '{"$schema":"switch-configuration-schema.json","version":"1.0","switches":{},"accessPoints":{},"wifiController":{}}' > "${f}"
        fi
    done
}

# Atomic jq update of the desired file: jq_desired '<filter>' [args...]
jq_desired() {
    local filter="$1"; shift
    local tmp
    tmp="$(mktemp)"
    if jq "$@" "${filter}" "${DESIRED}" > "${tmp}"; then
        mv "${tmp}" "${DESIRED}"
    else
        rm -f "${tmp}"
        die "Failed to update ${DESIRED}"
    fi
}

# Active VLAN tags as a JSON array of integers (the trunk set for node uplinks).
active_vlans_json() {
    vmnet_all_active_tags "${ZONES_FILE}" \
        | tr ';' '\n' | sed '/^$/d' | jq -R 'tonumber' | jq -s 'sort'
}

# ── Inventory commands ───────────────────────────────────────────────

cmd_add() {
    local name="$1"; shift
    [[ -n "${name}" ]] || die "add requires a <name>"
    local vendor="" ip="" model="" location="" description=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --vendor) vendor="$2"; shift 2 ;;
            --ip) ip="$2"; shift 2 ;;
            --model) model="$2"; shift 2 ;;
            --location) location="$2"; shift 2 ;;
            --description) description="$2"; shift 2 ;;
            *) die "add: unknown option '$1'" ;;
        esac
    done
    [[ -n "${vendor}" ]] || die "add requires --vendor"
    [[ -n "${ip}" ]] || die "add requires --ip"
    if jq -e --arg n "${name}" '.switches | has($n)' "${DESIRED}" >/dev/null; then
        die "Switch '${name}' already exists (use 'port' to edit, 'remove' first to recreate)"
    fi
    jq_desired '.switches[$n] = {vendor:$v, model:$m, managementIp:$ip, location:$loc, description:$d, ports:{}}' \
        --arg n "${name}" --arg v "${vendor}" --arg m "${model}" --arg ip "${ip}" --arg loc "${location}" --arg d "${description}"
    info "${GN}✓${CL} added switch '${name}' (${vendor}, ${ip})"
}

cmd_remove() {
    local name="$1"
    [[ -n "${name}" ]] || die "remove requires a <name>"
    jq -e --arg n "${name}" '.switches | has($n)' "${DESIRED}" >/dev/null \
        || die "Switch '${name}' not found"
    jq_desired 'del(.switches[$n])' --arg n "${name}"
    info "${GN}✓${CL} removed switch '${name}'"
}

cmd_list() {
    local count
    count=$(jq -r '.switches | length' "${DESIRED}")
    info "${BOLD}Switches (${count}):${CL}"
    jq -r '.switches | to_entries[] | "  \(.key)  [\(.value.vendor)]  \(.value.managementIp)  ports=\(.value.ports|length)  \(.value.description // "")"' "${DESIRED}"
    local apc
    apc=$(jq -r '.accessPoints // {} | length' "${DESIRED}")
    [[ "${apc}" -gt 0 ]] && info "${BOLD}Access points (${apc}):${CL} (manage with ap-manager)"
    return 0
}

cmd_show() {
    local name="$1"
    [[ -n "${name}" ]] || die "show requires a <name>"
    jq -e --arg n "${name}" '.switches | has($n)' "${DESIRED}" >/dev/null \
        || die "Switch '${name}' not found"
    jq --arg n "${name}" '.switches[$n]' "${DESIRED}"
}

# Parse a --connected-to spec "type[:target[:port]:iface]" into a JSON object.
_parse_connected_to() {
    local spec="$1" mac="$2"
    local -a p
    IFS=':' read -ra p <<< "${spec}"
    local type="${p[0]}" target="${p[1]:-}" port="" iface=""
    case "${#p[@]}" in
        3) iface="${p[2]}" ;;                 # type:target:iface
        4) port="${p[2]}"; iface="${p[3]}" ;; # type:target:port:iface
    esac
    jq -n --arg t "${type}" --arg tgt "${target}" --arg p "${port}" --arg i "${iface}" --arg m "${mac}" \
        '{type:$t}
         + (if $tgt!="" then {target:$tgt} else {target:null} end)
         + (if $p!=""   then {port:$p} else {} end)
         + (if $i!=""   then {interface:$i} else {} end)
         + (if $m!=""   then {mac:$m} else {} end)'
}

cmd_port() {
    local sw="$1" port="$2"; shift 2 2>/dev/null || die "port requires <switch> <port>"
    [[ -n "${sw}" && -n "${port}" ]] || die "port requires <switch> <port>"
    jq -e --arg n "${sw}" '.switches | has($n)' "${DESIRED}" >/dev/null \
        || die "Switch '${sw}' not found (add it first)"

    local mode="" tagged="" native="" zone="" conn="" mac="" source="manual" description=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --mode) mode="$2"; shift 2 ;;
            --tagged) tagged="$2"; shift 2 ;;
            --native) native="$2"; shift 2 ;;
            --zone) zone="$2"; shift 2 ;;
            --connected-to) conn="$2"; shift 2 ;;
            --mac) mac="$2"; shift 2 ;;
            --source) source="$2"; shift 2 ;;
            --description) description="$2"; shift 2 ;;
            *) die "port: unknown option '$1'" ;;
        esac
    done

    # Start from the existing port (if any) so partial edits merge.
    local cur
    cur=$(jq -c --arg n "${sw}" --arg p "${port}" '.switches[$n].ports[$p] // {mode:"access", source:"manual"}' "${DESIRED}")

    local upd="${cur}"
    [[ -n "${mode}" ]]        && upd=$(jq -c --arg v "${mode}"   '.mode=$v' <<< "${upd}")
    [[ -n "${source}" ]]      && upd=$(jq -c --arg v "${source}" '.source=$v' <<< "${upd}")
    [[ -n "${description}" ]] && upd=$(jq -c --arg v "${description}" '.description=$v' <<< "${upd}")
    [[ -n "${zone}" ]]        && upd=$(jq -c --arg v "${zone}"   '.zone=$v' <<< "${upd}")
    if [[ -n "${tagged}" ]]; then
        local tj
        tj=$(echo "${tagged}" | tr ',;' '\n' | sed '/^$/d' | jq -R 'tonumber' | jq -s 'sort')
        upd=$(jq -c --argjson v "${tj}" '.taggedVlans=$v' <<< "${upd}")
    fi
    if [[ -n "${native}" ]]; then
        upd=$(jq -c --argjson v "${native}" '.nativeVlan=$v' <<< "${upd}")
    fi
    if [[ -n "${conn}" ]]; then
        local cj
        cj=$(_parse_connected_to "${conn}" "${mac}")
        upd=$(jq -c --argjson v "${cj}" '.connectedTo=$v' <<< "${upd}")
    fi

    jq_desired '.switches[$n].ports[$p] = $port' --arg n "${sw}" --arg p "${port}" --argjson port "${upd}"
    info "${GN}✓${CL} ${sw} port ${port}: $(jq -c . <<< "${upd}")"
}

# ── Phase 0: update-desired (zones.json -> desired.json) ─────────────

cmd_update_desired() {
    info "${BOLD}update-desired${CL} (zones.json → desired.json)"
    local active changed
    active=$(active_vlans_json)
    # source:zones trunk ports carry the full active set; access ports with a
    # 'zone' field track that zone's current VLAN tag (#334/#335 analog for L2).
    # manual/discovered ports WITHOUT a zone field are preserved untouched.
    changed=$(jq --argjson active "${active}" --slurpfile z "${ZONES_FILE}" '
        ([.switches[].ports[]
          | select(.source=="zones" and .mode=="trunk")
          | select((.taggedVlans // []) != $active)] | length) as $trunk_changes
        | .switches |= map_values(
            .ports |= map_values(
                if .source=="zones" and .mode=="trunk" then .taggedVlans = $active
                else . end
                | if (.mode=="access" and (.zone // "")!="" and ($z[0][.zone].vlantag != null))
                  then .nativeVlan = $z[0][.zone].vlantag else . end
            ))
        | {result: ., trunk_changes: $trunk_changes}
    ' "${DESIRED}")
    echo "${changed}" | jq '.result' > "${DESIRED}.tmp" && mv "${DESIRED}.tmp" "${DESIRED}"
    local tc
    tc=$(echo "${changed}" | jq -r '.trunk_changes')
    info "  active VLAN set: $(echo "${active}" | jq -rc 'join(",")')"
    info "  source:zones trunk ports updated: ${tc}"
    return 0
}

# ── Phase 1: interrogate (live switches -> actual.json, via plugin) ──

select_plugin() {
    local vendor="$1" model="${2:-}" p
    for p in "${PLUGIN_DIR}"/*.sh; do
        [[ "$(basename "$p")" == "manual.sh" ]] && continue
        # shellcheck disable=SC1090
        ( . "$p"; plugin_supports "${vendor}" "${model}" ) >/dev/null 2>&1 && { echo "$p"; return 0; }
    done
    echo "${PLUGIN_DIR}/manual.sh"
}

cmd_interrogate() {
    info "${BOLD}interrogate${CL} (live switches → actual.json)"
    [[ -f "${ACTUAL}" ]] || ensure_files
    local names name vendor ip plugin state
    names=$(jq -r '.switches | keys[]' "${DESIRED}")
    if [[ -z "${names}" ]]; then info "  (no switches in inventory)"; return 0; fi
    while IFS= read -r name; do
        vendor=$(jq -r --arg n "${name}" '.switches[$n].vendor' "${DESIRED}")
        ip=$(jq -r --arg n "${name}" '.switches[$n].managementIp' "${DESIRED}")
        plugin=$(select_plugin "${vendor}")
        # shellcheck disable=SC1090
        state=$( . "${plugin}"; plugin_interrogate "${name}" "${ip}" 2>/dev/null )
        info "  ${name}: interrogated via $(basename "${plugin}" .sh) plugin"
        # manual plugin returns {} → keep existing actual entry untouched.
        if [[ -n "${state}" && "${state}" != "{}" ]]; then
            local tmp; tmp="$(mktemp)"
            jq --arg n "${name}" --argjson s "${state}" '.switches[$n] = $s' "${ACTUAL}" > "${tmp}" && mv "${tmp}" "${ACTUAL}"
        fi
    done <<< "${names}"
    return 0
}

# ── Phase 2: delta (desired vs actual) ──────────────────────────────
# Emits a JSON object {switch -> {changes:[{action,description,...}]}} on stdout
# (fd 3 when called internally) and a human report on stderr-ish info lines.

compute_delta() {
    jq -n --slurpfile d "${DESIRED}" --slurpfile a "${ACTUAL}" '
      ($d[0].switches // {}) as $des
      | ($a[0].switches // {}) as $act
      | reduce ($des | keys[]) as $sw ({};
          . + {($sw): {
              changes: [
                ($des[$sw].ports // {} | to_entries[]) as $p
                | ($act[$sw].ports[$p.key]) as $ap
                | if $ap == null then
                    {action:"configure-port", port:$p.key,
                     description:"port \($p.key) not on switch yet (\($p.value.mode))"}
                  elif $p.value.mode=="trunk" then
                    (((($p.value.taggedVlans // []) - ($ap.taggedVlans // [])) ) as $addv
                     | ((($ap.taggedVlans // []) - ($p.value.taggedVlans // []))) as $delv
                     | if ($addv|length)>0 or ($delv|length)>0 then
                         {action:"trunk-vlans", port:$p.key,
                          add:$addv, remove:$delv,
                          description:"port \($p.key) trunk: +\($addv|join(",")) -\($delv|join(","))"}
                       else empty end)
                  elif $p.value.mode=="access" then
                    (if ($p.value.nativeVlan != $ap.nativeVlan) then
                       {action:"access-vlan", port:$p.key,
                        from:$ap.nativeVlan, to:$p.value.nativeVlan,
                        description:"port \($p.key) access VLAN \($ap.nativeVlan) -> \($p.value.nativeVlan)"}
                     else empty end)
                  else empty end
              ],
              discovered: [
                (($act[$sw].ports // {} | keys) - ($des[$sw].ports // {} | keys))[]
              ]
          }})
    '
}

cmd_delta() {
    local delta total=0 disc=0
    delta=$(compute_delta)
    info "${BOLD}delta${CL} (desired vs actual)"
    local sw
    for sw in $(echo "${delta}" | jq -r 'keys[]'); do
        local n d
        n=$(echo "${delta}" | jq -r --arg s "${sw}" '.[$s].changes | length')
        d=$(echo "${delta}" | jq -r --arg s "${sw}" '.[$s].discovered | length')
        total=$((total + n)); disc=$((disc + d))
        if [[ "${n}" -gt 0 ]]; then
            warn "  ${sw}: ${n} change(s)"
            echo "${delta}" | jq -r --arg s "${sw}" '.[$s].changes[] | "      \(.action): \(.description)"'
        else
            info "  ${GN}✓${CL} ${sw}: in sync"
        fi
        if [[ "${d}" -gt 0 ]]; then
            warn "  ${sw}: ${d} discovered port(s): $(echo "${delta}" | jq -r --arg s "${sw}" '.[$s].discovered | join(", ")')"
        fi
    done
    [[ "$(echo "${delta}" | jq -r 'keys|length')" -eq 0 ]] && info "  (no switches in inventory)"
    DELTA_TOTAL="${total}"
    return 0
}

# ── Phase 3: apply (plugin push / manual print) ─────────────────────

cmd_apply() {
    local delta sw vendor changes plugin rc manual=0 applied=0
    delta=$(compute_delta)
    info "${BOLD}apply${CL}"
    for sw in $(echo "${delta}" | jq -r 'keys[]'); do
        changes=$(echo "${delta}" | jq -c --arg s "${sw}" '{changes: .[$s].changes}')
        [[ "$(echo "${changes}" | jq '.changes|length')" -eq 0 ]] && continue
        vendor=$(jq -r --arg n "${sw}" '.switches[$n].vendor' "${DESIRED}")
        plugin=$(select_plugin "${vendor}")
        rc=0
        # shellcheck disable=SC1090
        ( . "${plugin}"; plugin_apply "${sw}" "${changes}" ) || rc=$?
        if [[ "${rc}" -eq 0 ]]; then
            info "  ${GN}✓${CL} ${sw}: applied via $(basename "${plugin}" .sh)"
            applied=$((applied + 1))
        else
            manual=$((manual + 1))
        fi
    done
    APPLY_MANUAL="${manual}"; APPLY_DONE="${applied}"
    return 0
}

# ── Phase 4: confirm (record applied state; register discovered) ────

cmd_confirm() {
    info "${BOLD}confirm${CL} (record applied state in actual.json)"
    ensure_files
    # Record desired switch/port state as actual (operator applied it / plugin did).
    local tmp; tmp="$(mktemp)"
    jq --slurpfile d "${DESIRED}" '.switches = ($d[0].switches // {})' "${ACTUAL}" > "${tmp}" && mv "${tmp}" "${ACTUAL}"
    info "  ${GN}✓${CL} actual.json updated to match applied desired state"
    return 0
}

# ── reconcile (the five verbs in order) ─────────────────────────────

cmd_reconcile() {
    local apply="$1"
    DELTA_TOTAL=0; APPLY_MANUAL=0; APPLY_DONE=0
    cmd_update_desired; echo ""
    cmd_interrogate; echo ""
    cmd_delta; echo ""
    if [[ "${apply}" -eq 1 ]]; then
        cmd_apply; echo ""
        if [[ "${APPLY_MANUAL:-0}" -eq 0 ]]; then
            cmd_confirm
            info "${GN}switch-manager: converged${CL} (${APPLY_DONE:-0} applied)"
            return 0
        fi
        warn "switch-manager: ${APPLY_MANUAL} switch(es) need MANUAL application — apply on the device, then run: switch-manager confirm"
        return 2
    fi
    if [[ "${DELTA_TOTAL:-0}" -gt 0 ]]; then
        warn "switch-manager: ${DELTA_TOTAL} change(s) pending. Re-run with --apply."
        return 2
    fi
    info "${GN}switch-manager: in sync${CL}"
    return 0
}

# ── Main ─────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-}"
    [[ -z "${cmd}" || "${cmd}" == "-h" || "${cmd}" == "--help" ]] && { usage; exit 0; }
    shift || true
    [[ -f "${ZONES_FILE}" ]] || die "zones.json not found: ${ZONES_FILE}"
    ensure_files

    case "${cmd}" in
        add)            cmd_add "$@" ;;
        remove)         cmd_remove "${1:-}" ;;
        list)           cmd_list ;;
        show)           cmd_show "${1:-}" ;;
        port)           cmd_port "$@" ;;
        update-desired) cmd_update_desired ;;
        interrogate)    cmd_interrogate ;;
        delta)          cmd_delta ;;
        apply)          cmd_apply ;;
        confirm)        cmd_confirm ;;
        reconcile)
            local apply=0
            [[ "${1:-}" == "--apply" ]] && apply=1
            cmd_reconcile "${apply}"
            ;;
        *) die "Unknown command: ${cmd} (try --help)" ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
