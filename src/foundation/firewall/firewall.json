{
  "description": "The TAPPaaS Firewall VM (OPNsense)",
  "version": "1.0",
  "tier": "foundation",
  "vmname": "firewall",
  "vmid": 110,
  "vmtag": "TAPPaaS,Foundation",
  "zone0": "mgmt",
  "zone1": "mgmt",
  "ports": [
    {
      "port": 80,
      "protocol": "TCP",
      "description": "Caddy HTTP (ACME challenges + redirect to HTTPS)"
    },
    {
      "port": 443,
      "protocol": "TCP",
      "description": "Caddy HTTPS (reverse-proxy entry for all published services)"
    }
  ],
  "ingress": [
    {
      "from": "internet",
      "ports": [
        80,
        443
      ],
      "description": "Caddy reverse-proxy entry — public HTTPS for proxyAllowedZones=['internet'] services"
    }
  ],
  "dependsOn": [
    "cluster:vm",
    "cluster:ha",
    "firewall:proxy"
  ],
  "provides": [
    "firewall",
    "proxy",
    "rules",
    "discovery",
    "dns",
    "nat"
  ],
  "config": {
    "cluster:vm": {
      "bios": "ovmf",
      "ostype": "other",
      "cores": 4,
      "memory": "8192",
      "diskSize": "32G",
      "storage": "tanka1",
      "imageType": "img",
      "image": "tappaas-firewall.qcow2.zst",
      "imageLocation": "https://github.com/TAPPaaS/TAPPaaS/releases/download/opnsense-firewall-v1.1/",
      "cloudInit": "false",
      "bridge0": "lan",
      "trunks0": "ALL",
      "bridge1": "wan"
    },
    "firewall:proxy": {
      "proxyPort": 8443,
      "proxyUpstreamTls": "true",
      "proxyTls": "dns01",
      "proxyAllowedZones": [
        "mgmt"
      ]
    }
  }
}
