{
  "description": "The TAPPaaS NixOS VM Template",
  "version": "1.1",
  "location": "/home/tappaas/TAPPaaS/src/foundation/templates",
  "vmname": "tappaas-nixos",
  "vmid": 8080,
  "vmtag": "TAPPaaS,Foundation",
  "zone0": "mgmt",
  "dependsOn": [
    "cluster:vm"
  ],
  "provides": [
    "nixos"
  ],
  "config": {
    "cluster:vm": {
      "bios": "ovmf",
      "cores": 2,
      "memory": "4096",
      "diskSize": "16G",
      "storage": "tanka1",
      "imageType": "img",
      "image": "tappaas-nixos.qcow2.zst",
      "imageLocation": "https://github.com/TAPPaaS/TAPPaaS/releases/download/nixos-template-v1.1/",
      "autoInstall": false,
      "bridge0": "lan"
    }
  }
}
