{
  "description": "Identity OIDC test webserver (dependsOn identity:identity) — identity/test.sh --deep",
  "version": "0.1",
  "vmname": "test-idoidc",
  "vmid": 927,
  "vmtag": "TAPPaaS,Test,Identity",
  "node": "tappaas1",
  "cores": 1,
  "memory": "2048",
  "diskSize": "16G",
  "storage": "tanka1",
  "imageType": "clone",
  "image": "8080",
  "bridge0": "lan",
  "zone0": "srvWork",
  "proxyPort": 8080,
  "ports": [
    { "port": 8080, "protocol": "TCP", "description": "Test webserver" }
  ],
  "ingress": [
    { "from": "dmz", "ports": [8080], "description": "Caddy reverse proxy (dmz) forwards the public hostname to the webserver" }
  ],
  "identity": {
    "providesAdminRole": true,
    "oidcRedirectPaths": ["/oidc/callback"]
  },
  "dependsOn": [
    "cluster:vm",
    "templates:nixos",
    "firewall:proxy",
    "identity:identity",
    "firewall:rules"
  ]
}
