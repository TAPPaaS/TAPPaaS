{
  "description": "Authentik SSO identity provider for TAPPaaS",
  "version": "0.5.0",
  "releaseDate": "2026-02-17",
  "maintainer": "@larsrossen",
  "status": "Development",
  "vmname": "identity",
  "vmid": 140,
  "vmtag": "TAPPaaS,Foundation",
  "zone0": "mgmt",
  "dependsOn": [
    "cluster:vm",
    "cluster:ha",
    "templates:nixos",
    "backup:vm",
    "firewall:proxy"
  ],
  "provides": [
    "accessControl",
    "identity"
  ],
  "config": {
    "cluster:vm": {
      "cores": 2,
      "memory": "4096",
      "diskSize": "32G",
      "storage": "tanka1",
      "imageType": "clone",
      "image": "8080",
      "bridge0": "lan"
    },
    "firewall:proxy": {
      "proxyPort": 9000,
      "proxyAllowedZones": [
        "internet"
      ]
    }
  }
}
